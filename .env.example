# --- Discord Bot Config ---
DISCORD_TOKEN=your_bot_token_here
CLIENT_ID=your_client_id_here
GUILD_ID=your_server_id_here

# --- ID Card System ---
REQUIRED_ROLE_ID=      # Role required to create an ID
ADMIN_ROLE_ID=         # Role(s) can view other's IDs (comma separated)

# --- Fine & Violation System ---
STAFF_CHANNEL_ID=      # Where fine requests are sent
STAFF_ROLE_IDS=        # Roles that can approve/reject fines (space separated)
OFFICER_PANEL_ROLE_ID= # Role that can see the 'File Fine' panel
PD_CHANNEL_ID=         # Channel where the persistent panel lives

# --- Dashboard Config ---
DASHBOARD_PORT=8000
DASHBOARD_ADMIN_PASSWORD=admin123 # Password to access sensitive records (optional)
